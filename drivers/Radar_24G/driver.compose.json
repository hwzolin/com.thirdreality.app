{
  "name": {
    "en": "Smart Presence Sensor R2"
  },
  "class": "sensor",
  "capabilities": ["measure_battery", "alarm_motion"],
  "platforms": ["local", "cloud"],
  "connectivity": ["zigbee"],
  "energy": {
    "batteries": ["AA", "AA", "AA"]
  },
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png"
  },
  "zigbee": {
    "manufacturerName": ["Thirdreality", "Third Reality, Inc"],
    "productId": ["3RPS01083Z"],
    "endpoints": {
      "1": {
        "clusters": [0, 1, 1280, 65281],
        "bindings": [1, 1280]
      }
    },
    "learnmode": {
      "instruction": {
        "en": "Press and hold the `Level` button for more than 10 seconds until the sensitivity indicator turns on. Release the button, and the device will enter pairing mode.\nConfirm the sensitivity indicator is flashing rapidly."
      }
    }
  }
}
